{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PRForge Mesh Submission",
  "description": "Schema for .prforge/outbox/submission.json — written by worker when reaching approval_ready in Manager Mode",
  "type": "object",
  "required": ["job_id", "node_id", "cluster", "repo", "pr_number", "head_branch", "base_branch", "submitted_at", "artifacts", "diff_hash", "status"],
  "additionalProperties": false,
  "properties": {
    "job_id": { "type": "string", "minLength": 1 },
    "node_id": { "type": "string", "minLength": 1 },
    "cluster": { "type": "string", "minLength": 1 },
    "repo": { "type": "string", "pattern": "^[^/]+/[^/]+$" },
    "pr_number": { "type": "integer", "minimum": 1 },
    "head_branch": { "type": "string" },
    "base_branch": { "type": "string" },
    "submitted_at": { "type": "string" },
    "status": { "const": "WorkerSubmissionReady" },
    "diff_hash": { "type": "string", "minLength": 1 },
    "artifacts": {
      "type": "object",
      "description": "SHA256 hashes of required .prforge artifacts",
      "properties": {
        "approval.md": { "type": "string" },
        "validation_ledger.md": { "type": "string" },
        "dod.md": { "type": "string" },
        "hostile_review.md": { "type": "string" }
      }
    }
  }
}
