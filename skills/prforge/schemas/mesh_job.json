{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PRForge Mesh Job",
  "description": "Schema for Redis job hash: Workflow:<cluster>:job:<job_id> and .prforge/inbox/job.json",
  "type": "object",
  "required": ["job_id", "type", "priority", "repo", "pr_number", "base_branch", "head_branch", "source_url", "created_by", "status", "created_at"],
  "additionalProperties": true,
  "properties": {
    "job_id": { "type": "string", "minLength": 1 },
    "type": {
      "type": "string",
      "enum": ["review_response", "pr_polish", "ci_fix_related_to_branch", "audit_only"]
    },
    "priority": {
      "type": "string",
      "enum": ["P0", "P1", "P2", "P3", "P4"]
    },
    "repo": {
      "type": "string",
      "description": "org/repo slug (e.g. 'torvalds/linux')",
      "pattern": "^[^/]+/[^/]+$"
    },
    "pr_number": {
      "description": "PR number — integer when in inbox/job.json, string in Redis hash",
      "oneOf": [
        { "type": "integer", "minimum": 1 },
        { "type": "string", "pattern": "^[0-9]+$" }
      ]
    },
    "base_branch": { "type": "string", "minLength": 1 },
    "head_branch": { "type": "string", "minLength": 1 },
    "source_url": { "type": "string", "pattern": "^https://github.com/" },
    "created_by": {
      "type": "string",
      "enum": ["auditor", "coordinator", "manual"]
    },
    "status": {
      "type": "string",
      "enum": ["queued", "assigned", "active", "approval_ready", "blocked", "complete", "failed", "stale"]
    },
    "assigned_node": { "type": "string" },
    "lease_id": { "type": "string" },
    "created_at": { "type": "string" },
    "assigned_at": { "type": "string" },
    "completed_at": { "type": "string" },
    "constraints": {
      "description": "JSON-serialized constraint object or inline object (inbox/job.json)",
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "properties": {
            "public_actions_require_approval": { "type": "boolean" },
            "only_address_main_review_feedback": { "type": "boolean" },
            "ignore_unrelated_ci": { "type": "boolean" },
            "do_not_create_new_pr": { "type": "boolean" }
          }
        }
      ]
    }
  }
}
