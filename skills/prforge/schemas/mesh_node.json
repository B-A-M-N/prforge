{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PRForge Mesh Node",
  "description": "Schema for Redis node hash: Workflow:<cluster>:node:<node_id>",
  "type": "object",
  "required": ["node_id", "roles", "status", "capacity", "last_seen", "version"],
  "additionalProperties": true,
  "properties": {
    "node_id": { "type": "string", "minLength": 1 },
    "roles": {
      "type": "string",
      "description": "Comma-separated roles string as stored in Redis hash (e.g. 'worker' or 'coordinator,auditor')"
    },
    "status": {
      "type": "string",
      "enum": ["idle", "active", "offline", "draining"]
    },
    "capacity": {
      "type": "string",
      "description": "Serialized integer: '0' or '1'"
    },
    "active_job": {
      "type": "string",
      "description": "Current job_id or empty string"
    },
    "last_seen": {
      "type": "string",
      "description": "ISO 8601 timestamp of last heartbeat"
    },
    "repo_roots": {
      "type": "string",
      "description": "JSON-serialized array of repo root paths"
    },
    "version": { "type": "string" }
  }
}
