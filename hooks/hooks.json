{
  "description": "PRForge deterministic hooks",
  "hooks": {
    "PreToolUse": [
      {
        "description": "PRForge Bash safety gate — blocks unsafe git push/PR actions before they run",
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/preflight.sh\"",
            "timeout": 8
          }
        ]
      },
      {
        "description": "PRForge phase gate enforcer — blocks out-of-envelope tool usage per phase",
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/phase-gate-enforcer.sh\"",
            "timeout": 5
          }
        ]
      },
      {
        "description": "PRForge mesh lock guard — enforces distributed-local worktree and lock boundaries",
        "matcher": "Bash|Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/mesh-lock-guard.sh\"",
            "timeout": 5
          }
        ]
      },
      {
        "description": "PRForge phase boundary enforcer — blocks illegal phase transitions in state.json writes",
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/phase-boundary.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "description": "PRForge memory autocapture — logs events and registers artifacts after tool use",
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/memory-autocapture.sh\"",
            "timeout": 10
          }
        ]
      },
      {
        "description": "PRForge GitNexus intelligence — prompts intelligence gathering after read operations when state is active",
        "matcher": "Read|Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/gitnexus-intelligence.sh\"",
            "timeout": 15
          }
        ]
      },
      {
        "description": "PRForge blast radius tracker — computes blast radius after file edits",
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/blast-radius.sh\"",
            "timeout": 10
          }
        ]
      },
      {
        "description": "PRForge phase injector — after state.json writes, injects mandatory reminder to read the new phase playbook",
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/phase-injector.sh\"",
            "timeout": 5
          }
        ]
      },
      {
        "description": "PRForge discipline check — after Write/Edit/MultiEdit, verifies coding discipline compliance",
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/discipline-check.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "_install_note": "CLAUDE_PLUGIN_ROOT must resolve to the prforge plugin directory (containing this hooks/ folder). Verify with: echo ${CLAUDE_PLUGIN_ROOT}. If hooks silently fail, check this path first."
}
